{
  "name": "wolfe-radar",
  "version": "5.0.0",
  "description": "Gulp Bootstrap5 scss Pug",
  "main": "block.js",
  "type": "module",
  "scripts": {
    "dev": "gulp",
    "gulp": "gulp",
    "build": "NODE_ENV=production gulp build",
    "libs": "gulp libs",
    "lint:js": "biome check source/js block.js gulpfile.js gulp tests vitest.config.js",
    "lint:js:fix": "biome check --write source/js block.js gulpfile.js gulp tests vitest.config.js",
    "lint:css": "stylelint \"source/**/*.scss\"",
    "lint:css:fix": "stylelint \"source/**/*.scss\" --fix",
    "validate:html": "html-validate \"public/**/*.html\"",
    "lint": "npm run lint:js && npm run lint:css",
    "format": "biome check --write source/js block.js gulpfile.js gulp tests vitest.config.js && npm run lint:css:fix",
    "prepare": "husky",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:mutation": "stryker run"
  },
  "lint-staged": {
    "*.{js,json}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.scss": [
      "stylelint --fix"
    ]
  },
  "author": "Khalunin Pavel",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "autoprefixer": "^10.4.20",
    "bootstrap": "5.3.3",
    "browser-sync": "^3.0.2",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001777",
    "colors": "^1.4.0",
    "cssnano": "^7.0.6",
    "del": "^8.0.0",
    "fast-check": "^4.8.0",
    "gulp": "^5.0.0",
    "gulp-cheerio": "^1.0.0",
    "gulp-data": "^1.3.1",
    "gulp-imagemin": "^8.0.0",
    "gulp-notify": "^5.0.0",
    "gulp-npm-dist": "^1.0.4",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-pug": "^5.0.0",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.1.4",
    "gulp-sass": "^6.0.0",
    "gulp-sass-glob": "^1.1.0",
    "gulp-svg-sprite": "^2.0.3",
    "gulp-svgmin": "^4.1.0",
    "gulp-tabify": "0.0.2",
    "gulp-webp": "^4.0.1",
    "html-validate": "^9.5.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "imagemin-pngquant": "^9.0.2",
    "lint-staged": "^15.2.10",
    "node-html-parser": "^7.1.0",
    "postcss": "^8.5.3",
    "postcss-nested": "^7.0.2",
    "postcss-scss": "^4.0.9",
    "postcss-sort-media-queries": "^5.2.0",
    "sass": "1.77.6",
    "stylelint": "^16.10.0",
    "stylelint-declaration-strict-value": "^1.10.6",
    "stylelint-scss": "^6.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fancyapps/ui": "^5.0.36",
    "inputmask": "^5.0.9",
    "jquery": "^3.7.1",
    "select2": "^4.1.0-rc.0",
    "swiper": "^11.2.4"
  }
}
