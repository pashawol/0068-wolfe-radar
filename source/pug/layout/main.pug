		script.
			// Shared part loader for demo mode.
			// Keeps duplicated blocks visible in templates and avoids repeated fetches.
			const sharedPartCache = new Map();

			function addBlock(partName) {
				const wrap = document.querySelector(`#${partName}Wrap`);
				if (!wrap) return;

				const partRequest =
					sharedPartCache.get(partName) ||
					fetch(`parts/${partName}.html`)
						.then(response => (response.ok ? response.text() : ""))
						.catch(() => "");

				sharedPartCache.set(partName, partRequest);

				partRequest.then(text => {
					if (!text) return;
					const markerScript = wrap.previousElementSibling;
					wrap.insertAdjacentHTML("afterend", text);
					if (markerScript && markerScript.tagName === "SCRIPT") {
						markerScript.remove();
					}
					wrap.remove();
				});
			}
