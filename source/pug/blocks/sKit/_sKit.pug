mixin sKit()
	// start sKit
	+b.SECTION.sKit.section#sKit&attributes(attributes)
		.container
			+section-head('19 / КОМПЛЕКТ')
			+b.section-title
				h2 ЧТО ВХОДИТ В КОМПЛЕКТ РАДАРА ВУЛЬФА?
			+e.lead Вы получите торговый комбайн, обучение, поддержку и практическое сопровождение, чтобы быстрее встроить Волны Вульфа в свой трейдинг и перейти к получению результатов. В комплект входит:
			+e.body

				//- === Row 1: Радар Вульфа для MetaTrader 5 ===
				+e.row
					+e.panel
						+e.SPAN.panel-tag Основной продукт
						+e.panel-title Радар Вульфа для MetaTrader 5
						ul.sKit__panel-list
							li автоматическая разметка Волн Вульфа;
							li сканер рынка до 100 графиков;
							li визуальный тестер;
							li статистика стратегии прямо на графике;
							li риск-менеджер для расчета объема позиции;
							li уведомления о формировании паттернов и точках входа;
					+e.checks
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text обучение работе с системой
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text мастер-группа с разбором продвинутых нюансов работы с Радаром Вульфа;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text стратегические хакатоны;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text поддержка на весь срок лицензии лично от Владимира Чамина;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text робот для автоматического исполнения сделок* (*опционально).

				//- === Row 2: Обучение ===
				+e.row
					+e.panel
						+e.panel-top
							+e.SPAN.panel-tag Обучение
							+e.panel-title Обучение работе с Радаром
							+e.P.panel-desc Чтобы Вы быстро разобрались с системой, в комплект входит видеокурс по установке, настройке и практическому использованию Радара Вульфа.
						+e.P.panel-desc--strong Главная задача видеокурса — чтобы Вы по шагам прошли весь путь: от первого запуска и проверки стратегии до портфеля, уведомлений и реальной торговли.
					+e.checks
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text установку и запуск Радара Вульфа;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text поиск прибыльных активов и таймфреймов;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text создание торгового портфеля;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text работу с уведомлениями и сигналами;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text практическую торговлю вручную;
						+e.check-item
							+e.SPAN.check-mark ✓
							+e.SPAN.check-text настройку автоторговли для желающих

				//- === Row 3: Мастер-группа ===
				+e.row--equal
					+e.card.--main
						+e.card-inner
							+e.SPAN.panel-tag Продвинутая ценность комплекта
							+e.card-title Мастер-группа с Владимиром Чаминым
							+e.P.card-desc Это 6 онлайн-занятий с Владимиром Чаминым, где мы будем практически разбирать рынки, инструменты, таймфреймы и стратегии. Пару занятий мы посвятим продвинутым нюансам работы с Радаром Вульфа и созданию устойчивых портфелей, для надежного заработка.
						+e.P.card-desc--strong Мастер-группа – это практическая лаборатория, где Вы вместе с автором системы учитесь искать самые интересные возможности и исследовать новые рынки.
					+e.card
						+e.P.card-title--sm Главный формат остальных занятий — стратегические хакатоны, на которых мы будем:
						ul.sKit__card-list
							li брать рынки и активы, которые Вам интересны;
							li исследовать их с помощью Радара, прогонять на разных таймфреймах;
							li искать самые сильные связки;
							li детально анализировать статистику;
							li отбирать самые сильные активы/таймфреймы, помечать слабые варианты, на которых торговать не стоит;
							li собирать портфели для разных рынков и брокеров;
							li разбирать реальные счета и реальные торговые ситуации;
							li анализировать торговлю стратегий и корректировать результаты.

				//- === Row 4: Поддержка ===
				+e.row--support
					+e.card
						+e.SPAN.panel-tag Поддержка
						+e.card-title Поддержка на весь срок лицензии
						+e.P.card-desc Вы же планируете зарабатывать трейдингом не один год? Вопрос из реальной торговли может возникнуть у Вас и через 2 года трейдинга с Радаром.
						+e.P.card-desc Поэтому в комплект входит поддержка лично от Владимира Чамина на весь срок лицензии на Радар Вульфа!
						+e.P.card-desc Сам Радар – технологичный инструмент. Вам может понадобиться техническая помощь.
						+e.P.card-desc В технических моментах Вам может помочь Служба Заботы Инфоклуба.

				//- === CTA Banner ===
				+e.cta-banner
					.sKit__cta-ellipse(aria-hidden="true")
						+orbitFigure
					+e.cta-text
						+e.P.cta-heading Мы очень хотим помочь Вам получить высокие результаты.
						+e.P.cta-desc Поэтому Вы получите не «голый индикатор», а систему, обучение, практику, поддержку и среду, где можно быстрее прийти к реальным результатам и забирать профит.
						+e.P.cta-desc Радар Вульфа дает Вам не только технологию, но и путь внедрения этой технологии в Ваш трейдинг.
					+e.A.btn.btn.btn-primary(href="#sForm")
						span Забрать Радар Вульфа в максимальной комплектации!
						span.btn-arrow →
	// end sKit
