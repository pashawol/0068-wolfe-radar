mixin sHero()
	// start sHero
	+b.SECTION.sHero.section#sHero&attributes(attributes)
		.container
			+e.head
				+e.SPAN.num [ 01 ]
				+e.SPAN.tag ВОЛНЫ ВУЛЬФА · АВТОПОИСК
			+e.content
				+e.left
					+e.title
						span РАДАР
						+e.SPAN.title-accent ВУЛЬФА
					+e.P.lead Находит готовые сделки раньше большинства трейдеров и сразу показывает весь торговый план прямо на графике.
					+e.stats
						+e.stat
							+e.SPAN.stat-value 100+
							+e.SPAN.stat-text активов и таймфреймов мониторит в реальном времени.
						+e.stat
							+e.SPAN.stat-value AUTO
							+e.SPAN.stat-text находит редкий профессиональный паттерн: Волны Вульфа.
					+e.cta
						+e.A.btn.btn.btn-primary(href="#sForm")
							span Забрать Радар Вульфа
							span.btn-arrow →
						+e.P.note Для MetaTrader 5: фьючерсы, акции, Forex, металлы, криптовалюты, индексы.
				+e.right
					+e.chart-card
						+e.chart-head
							+e.SPAN.ticker EURUSD · H1
							+e.status
								+e.SPAN.status-dot
								+e.SPAN.status-label SCANNING
						+e.chart
							svg.sHero__chart-svg(viewBox="0 0 460 316" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" aria-hidden="true")
								g(stroke="rgba(255,255,255,0.06)" stroke-width="1")
									line(x1="0" y1="40" x2="460" y2="40")
									line(x1="0" y1="100" x2="460" y2="100")
									line(x1="0" y1="160" x2="460" y2="160")
									line(x1="0" y1="220" x2="460" y2="220")
									line(x1="0" y1="280" x2="460" y2="280")
								//- wolfe pattern price line
								polyline(points="20,150 75,105 130,180 185,135 240,210 295,170" fill="none" stroke="#f4f2ec" stroke-width="2" stroke-linejoin="round" stroke-linecap="round")
								//- projection to target
								line(x1="295" y1="170" x2="438" y2="112" stroke="#d29a45" stroke-width="1.5" stroke-dasharray="5 5")
								//- vertices
								g(fill="#15181b" stroke="#f4f2ec" stroke-width="2")
									circle(cx="75" cy="105" r="4")
									circle(cx="130" cy="180" r="4")
									circle(cx="185" cy="135" r="4")
									circle(cx="295" cy="170" r="4")
								//- entry point
								circle(cx="240" cy="210" r="5" fill="#e79017")
								//- target point
								circle(cx="438" cy="112" r="5" fill="#e79017")
							+e.SPAN.chart-label.--entry(style="left:46%;top:70%") ВХОД
							+e.SPAN.chart-label.--target(style="right:2%;top:30%") ЦЕЛЬ
					+e.author
						+e.author-info
							+e.P.author-name Владимир Чамин
							+e.P.author-role разработчик
							+e.P.author-role в трейдинге с 2003 г.
							+e.SPAN.author-tag ИНФОКЛУБ
					//- decorative orbit figure behind the author (Figma node 2003-1053)
					+e.figure(aria-hidden="true")
						+e.SPAN.figure-glow
						+e.SPAN.figure-ring.--r1
						+e.SPAN.figure-ring.--r2
						+e.SPAN.figure-ring.--r3
						+e.SPAN.figure-orbit.--mid
							+e.SPAN.figure-dot.--big
						+e.SPAN.figure-orbit.--mid.--alt
							+e.SPAN.figure-dot
						+e.SPAN.figure-orbit.--outer
							+e.SPAN.figure-dot
					img.sHero__photo(src="img/wolfe/hero/author-chamin.webp" alt="Владимир Чамин" width="496" height="757" loading="eager")
	// end sHero
