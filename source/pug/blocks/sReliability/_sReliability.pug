mixin sReliability()
	// start sReliability
	+b.SECTION.sReliability.section#sReliability&attributes(attributes)
		+e.decor(aria-hidden="true")
			img.sReliability__decor-img.sReliability__decor-img--g1(src="img/wolfe/sReliability/decor-g1.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--g2(src="img/wolfe/sReliability/decor-g2.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--g3(src="img/wolfe/sReliability/decor-g3.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--g4(src="img/wolfe/sReliability/decor-g4.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--g5(src="img/wolfe/sReliability/decor-g5.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--g6(src="img/wolfe/sReliability/decor-g6.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--v1(src="img/wolfe/sReliability/decor-v1.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--v2(src="img/wolfe/sReliability/decor-v2.svg" alt="")
			img.sReliability__decor-img.sReliability__decor-img--v3(src="img/wolfe/sReliability/decor-v3.svg" alt="")
		.container
			+section-head('13 / НАДЁЖНОСТЬ')
			+b.section-title
				h2 ПОЧЕМУ РАДАР НЕ ЛОМАЕТСЯ, КАК ОБЫЧНАЯ «КНОПКА»?
			+e.body
				+e.compare
					+e.card.--bad
						+e.SPAN.card-tag «КНОПКА-БАБЛО»
						+e.H3.card-heading Завязана на один сигнал, один график, один режим рынка и надежду, что так будет всегда.
						+e.P.card-text Но рынок меняется. Готова ли Ваша стратегия к завтрашнему рынку?
					+e.card.--good
						+e.SPAN.card-tag РАДАР ВУЛЬФА
						+e.H3.card-heading Быстро проверить рынок, отобрать сильные инструменты, заменить слабые и держать портфель в форме.
						+e.P.card-text Скорость поиска и проверки превращается в уверенность: Вы решаете на основе фактов, а не эмоций.
				+e.cta-bar
					+e.P.cta-text Вы сразу видите статистику, риск, потенциал сделки — и принимаете решение спокойно.
					+e.A.btn.btn.btn-primary(href="#sForm")
						span Получить Радар и зарабатывать уверенно
						span.btn-arrow →
	// end sReliability
