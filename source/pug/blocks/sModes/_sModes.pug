mixin sModes()
	// start sModes
	+b.SECTION.sModes.section--canvas#sModes&attributes(attributes)
		.container
			+section-head('14 / РЕЖИМЫ')
			+b.section-title
				h2 КАК ВСТРОИТЬ РАДАР В МОЙ ТРЕЙДИНГ?
			+e.SPAN.lead Выбирайте режим работы под текущие задачи:
			+e.body
				+e.cards
					+e.card
						+e.SPAN.card-num РЕЖИМ 1
						+e.H3.card-title Быстрое исследование рынков
						+e.card-text
							p Радар Вульфа превращает MetaTrader 5 в исследовательскую лабораторию Волн Вульфа. Вы можете:
							ul
								li быстро проверять любые активы;
								li менять таймфреймы от М1 до D1;
								li находить самые прибыльные рынки для заработка;
								li за секунду получать статистику на любом активе;
								li формировать портфели;
								li собирать коллекцию стратегий под свой стиль торговли.
							p Не нужно спорить, где Волны Вульфа работают лучше.
							p Исследуйте. Поставили Радар на график — и сразу увидели статистику, сделки, просадку, доходность и качество отработки паттернов.
					+e.card
						+e.SPAN.card-num РЕЖИМ 2
						+e.H3.card-title Визуализация и обучение
						+e.card-text
							p Радар поможет быстрее разобраться в логике Волн Вульфа.
							p Вы можете проматывать график или запускать визуальную демонстрацию торговли на истории и смотреть, как формируется паттерн, как стратегия ведет себя в реальной торговле.
							p Это буквально загружает в мозг живую механику паттерна. Вы видите, как Волны Вульфа отрабатывают на реальном графике и прокачиваете свою насмотренность.
					+e.card
						+e.SPAN.card-num РЕЖИМ 3
						+e.H3.card-title Торговля вручную с помощью советника
						+e.card-text
							p Это режим: увидел сигнал → поставил отложку → ушел.
							p Радар показывает Вам весь торговый план. Вы сами принимаете решение, вручную ставите отложенные ордера на вход и выход из сделки.
					+e.card
						+e.SPAN.card-num РЕЖИМ 4
						+e.H3.card-title Режим 4. Автоматическая торговля
						+e.card-text
							p Когда Вы готовы подключить робота, Радар может работать в автоматическом режиме.
				+e.pair
					+orbitFigure(class="sModes__orbit sModes__orbit--pair" aria-hidden="true")
					+e.P.pair-title Создается идеальная пара для трейдинга: Радар + Робот
					+e.pair-cols
						+e.pair-col
							p Радар находит торговую ситуацию
						+e.pair-col
							p Робот открывает и закрывает сделку по заданным правилам
						+e.pair-col
							p Радар думает, как аналитик
						+e.pair-col
							p Робот действует, как дисциплинированный коллега-трейдер
						+e.pair-col
							p Робот не устает. Не сомневается. Не передвигает стоп «на всякий случай». Не входит потому, что «очень хочется». Он просто выполняет правила.
					svg.sModes__pair-wave(viewBox="0 0 1000 80" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" overflow="visible")
						path(d="M8,60 C90,60 167,20 250,20 C333,20 417,38 500,38 C583,38 667,20 750,20 C833,20 910,60 992,60" stroke-width="1.5" stroke-dasharray="6 4" fill="none")
						circle(cx="8" cy="60" r="8" stroke-width="2")
						circle(cx="250" cy="20" r="8" stroke-width="2")
						circle(cx="500" cy="38" r="8" stroke-width="2")
						circle(cx="750" cy="20" r="8" stroke-width="2")
						circle(cx="992" cy="60" r="8" stroke-width="2")
				+e.outro
					+orbitFigure(class="sModes__orbit sModes__orbit--outro" aria-hidden="true")
					+e.outro-text
						p Сегодня Вы хотите торговать исключительно вручную, на конкретном рынке?
						p Завтра Вы захотите исследовать новые рынки?
						p Через месяц Вам захочется поставить торговлю на автомат?
						p Радар Вульфа будет полезен в каждом из этих сценариев.
					+e.A.btn.btn.btn-primary(href="#sForm")
						span Выбрать свой режим использования Радара
						span.btn-arrow →
	// end sModes
