mixin sWolfe()
	// start sWolfe
	+b.SECTION.sWolfe.section--canvas#sWolfe&attributes(attributes)
		.container
			+section-head('04 / ПАТТЕРН')
			+b.section-title
				h2 ЧТО ТАКОЕ ВОЛНЫ ВУЛЬФА?
			+e.body
				+e.cols
					+e.col-left
						+e.P.lead
							+e.SPAN.lead-accent Волны Вульфа — редкий паттерн
							| , который превращает хаос графика в геометрию сделки.
						+e.P.text Это модель из 5 точек, которая показывает, где искать вход, где защищать сделку и куда цена может дойти.
						+e.P.note Метод связывают с трейдером Биллом Вульфом. Его не изобрели, а обнаружили: цена движется волнами спроса и предложения, выходит из баланса и стремится вернуться к равновесию.
						+e.callout
							+e.P.callout-heading Главное преимущество Волн Вульфа — они дают сделке понятную геометрию. Они показывают конкретно:
							+e.chips
								+e.chip где вход
								+e.SPAN.sep →
								+e.chip где защита
								+e.SPAN.sep →
								+e.chip где цель
								+e.SPAN.sep →
								+e.chip когда движение должно развиться
						+e.P.sub-heading Волны Вульфа особенно ценят профессиональные трейдеры.
						+e.P.sub-text Правильно увидеть такой паттерн на живом графике непросто. Это похоже на 3D-картинку: сначала видишь только шум, а потом вдруг проступает четкая фигура сделки.
					+e.col-right
						img.sWolfe__chart-img(src="img/wolfe/sWolfe/pattern-chart.webp" alt="Пример паттерна Волны Вульфа — 5 точек на графике" loading="lazy")
				+e.P.complexity Именно поэтому Волны Вульфа долго оставались инструментом только для очень опытных трейдеров: нужно было уметь находить 5 ключевых точек, понимать геометрию движения, не путать настоящий паттерн с похожими случайными линиями и вовремя увидеть момент формирования точки входа.
				+e.H3.feature-heading Почему этот паттерн так интересен для торговли?
				+e.cards
					+e.card
						+e.card-icon
							img.sWolfe__icon-img(src="img/wolfe/sWolfe/icons-1.webp" alt="" aria-hidden="true" loading="lazy" width="94" height="94")
						+e.card-body
							+e.P.card-title Не Эллиотт и не волновая теория.
							+e.P.card-text Волны Вульфа — это графический паттерн из 5 точек, он не имеет отношения к волновому анализу.
					+e.card
						+e.card-icon
							img.sWolfe__icon-img(src="img/wolfe/sWolfe/icons-2.webp" alt="" aria-hidden="true" loading="lazy" width="94" height="94")
						+e.card-body
							+e.P.card-title Даёт не только направление, но и цель.
							+e.P.card-text У сделки появляется расчетная цель, а не просто ожидание «куда-нибудь вверх» или «куда-нибудь вниз».
					+e.card
						+e.card-icon
							img.sWolfe__icon-img(src="img/wolfe/sWolfe/icons-3.webp" alt="" aria-hidden="true" loading="lazy" width="94" height="94")
						+e.card-body
							+e.P.card-title Помогает увидеть разворот раньше толпы.
							+e.P.card-text Там, где большинство видит пробой, Волны Вульфа показывают точку возврата.
					+e.card
						+e.card-icon
							img.sWolfe__icon-img(src="img/wolfe/sWolfe/icons-4.webp" alt="" aria-hidden="true" loading="lazy" width="94" height="94")
						+e.card-body
							+e.P.card-title Подходит для разных рынков.
							+e.P.card-text Паттерн работает на фьючерсах МосБиржи, акциях, Forex, металлах, криптовалютах, индексах, на таймфреймах от М1 до D1.
				+e.P.rare
					+e.SPAN.rare-strong Это редкая торговая ситуация, но когда она появляется, опытные трейдеры всегда ликуют.
					|  Хорошие Волны Вульфа не появляются каждую минуту. Именно поэтому они ценны: это не шум, а осмысленная геометрия рынка, которая отлично отрабатывает в торговле.
				+e.display
					+e.SPAN.display-plain Один паттерн — три ответа:
					= ' '
					+e.SPAN.display-accent вход, стоп, цель.
				+e.two-cols
					+e.P.two-col-text Главная фишка Волн Вульфа – паттерн показывает не только точку входа и уровень стоп-лосса, он показывает еще и расчетную цель – куда придет рынок.
					+e.two-col-box
						+e.P.two-col-bold И еще более редкая фишка! Этот паттерн показывает не только «куда» дойдет цена, но и «примерно когда».
						+e.P.two-col-note У Вас появляется еще и ориентир по времени.
	// end sWolfe
