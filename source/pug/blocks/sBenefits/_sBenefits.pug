mixin sBenefits()
	// start sBenefits
	+b.SECTION.sBenefits.section--canvas#sBenefits&attributes(attributes)
		.container
			+section-head('20 / ВЫГОДЫ')
			+e.body
				+b.section-title
					h2 ЧТО ВЫ НА САМОМ ДЕЛЕ ПРИОБРЕТАЕТЕ ВМЕСТЕ С РАДАРОМ ВУЛЬФА?
				+e.P.lead Большинство трейдеров приходят на рынок за свободой и дополнительным доходом. А получают совсем другое:
				+e.list
					+e.list-item
						+e.list-icon
							svg(width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true")
								path(d="M12 4L4 12M4 4L12 12" stroke="#FF4144" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round")
						+e.SPAN.list-text часами смотрят в графики;
					+e.list-item
						+e.list-icon
							svg(width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true")
								path(d="M12 4L4 12M4 4L12 12" stroke="#FF4144" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round")
						+e.SPAN.list-text сомневаются перед каждой сделкой;
					+e.list-item
						+e.list-icon
							svg(width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true")
								path(d="M12 4L4 12M4 4L12 12" stroke="#FF4144" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round")
						+e.SPAN.list-text боятся пропустить вход и боятся входить;
					+e.list-item
						+e.list-icon
							svg(width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true")
								path(d="M12 4L4 12M4 4L12 12" stroke="#FF4144" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round")
						+e.SPAN.list-text не знают, работает ли их стратегия вообще;
					+e.list-item
						+e.list-icon
							svg(width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true")
								path(d="M12 4L4 12M4 4L12 12" stroke="#FF4144" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round")
						+e.SPAN.list-text торгуют один-два инструмента и выдумывают сделки вместо того, чтобы дожидаться качественных сигналов;
					+e.list-item
						+e.list-icon
							svg(width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true")
								path(d="M12 4L4 12M4 4L12 12" stroke="#FF4144" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round")
						+e.SPAN.list-text постоянно испытывают стресс из-за неопределённости.
				+b.section-title
					h2 РАДАР ВУЛЬФА СОЗДАН ДЛЯ ТОГО, ЧТОБЫ УБРАТЬ ЭТИ ПРОБЛЕМЫ ИЗ ТРЕЙДИНГА
				+e.cards-grid
					+e.cards-row
						+e.card
							+e.P.card-title Готовую систему торговли по Волнам Вульфа
							+e.P.card-text Не нужно самостоятельно изучать сложную разметку паттерна и годами нарабатывать насмотренность. Радар сам найдёт и покажет торговую ситуацию.
						+e.card
							+e.P.card-title Готовый торговый план по каждой сделке
							+e.P.card-text Все ключевые точки появляются прямо на графике.
						+e.card
							+e.P.card-title Уверенность перед входом в сделку
							+e.P.card-text Вы можете за секунды проверить статистику стратегии на любом активе и таймфрейме, прежде чем рисковать деньгами.
					+e.cards-row
						+e.card
							+e.P.card-title Экономию огромного количества времени
							+e.P.card-text Не нужно вручную открывать десятки графиков, искать точки и строить линии. Радар делает это автоматически.
						+e.card
							+e.P.card-title Защиту от большинства типичных ошибок трейдера
							+e.P.card-text Ошибки в разметке, эмоциональные входы, отсутствие стопа, торговля «на глаз», попытки угадать рынок — всё это становится значительно менее вероятным.
						+e.card
							+e.P.card-title Меньше решений — меньше ошибок
							+e.P.card-text Внимание — ресурс психики человека, он имеет свойство заканчиваться. Радар защищает Вас от когнитивных ошибок, забирая на себя рутинные процессы.
					+e.cards-row
						+e.card
							+e.P.card-title Возможность торговать тогда, когда удобно Вам
							+e.P.card-text Утром, вечером, несколько часов после работы или в свободные промежутки дня.
						+e.card
							+e.P.card-title Постоянный поток торговых возможностей
							+e.P.card-text Вместо ожидания сигнала на одном графике Вы наблюдаете сразу целый список активов через сканер и портфель инструментов.
						+e.card
							+e.P.card-title Возможность быстро находить лучшие активы и таймфреймы
							+e.P.card-text Вы не привязываетесь к одному инструменту. Радар помогает искать там, где сейчас есть наиболее интересные возможности.
					+e.cards-row.--four
						+e.card
							+e.P.card-title Гибкость в работе
							+e.P.card-text Можно торговать вручную, использовать уведомления и отложенные ордера или полностью автоматизировать исполнение через робота.
						+e.card
							+e.P.card-title Один инструмент для разных рынков
							+e.P.card-text Forex, золото, серебро, криптовалюты, акции, индексы, российские и американские фьючерсы и т.д.
						+e.card
							+e.P.card-title Быстрый старт даже без опыта в трейдинге
							+e.P.card-text Если Вы новичок, Радар покажет, где искать вход, где ставить стоп и где фиксировать прибыль.
						+e.card
							+e.P.card-title Поддержку и обучение
							+e.P.card-text Вы получаете не просто программу, а готовую систему внедрения Радара Вульфа в свой трейдинг.
				+e.featured
					+e.featured-content
						+e.SPAN.featured-label САМАЯ ГЛАВНАЯ ВЫГОДА
						+e.P.featured-heading Радар Вульфа экономит не только деньги, но и годы обучения.
						+e.P.featured-body То, что раньше требовало опыта, насмотренности и постоянной ручной работы, теперь доступно через готовую систему поиска и сопровождения сделок.
						+e.P.featured-body Уже через неделю использования Радара Ваш трейдинг перейдёт на качественно новый уровень. Вы перестанете тратить часы на то, что программа умеет делать за секунды.
					img.sBenefits__featured-img(src="img/wolfe/sBenefits/chart-trading.webp" alt="" aria-hidden="true" loading="lazy" width="516" height="522")
					img.sBenefits__featured-glow(src="img/wolfe/sBenefits/glow.svg" alt="" aria-hidden="true" loading="lazy" width="972" height="1004")
				+e.closing
					+e.P.closing-p Сегодня у Вас есть возможность начать торговать по одному из самых интересных разворотных паттернов рынка. Вы уже понимаете, что получите. Осталось выбрать формат доступа и начать пользоваться Радаром Вульфа уже сегодня.
					+e.P.closing-cta Всего один шаг. Радар может стать Вашим через секунды… ↓↓↓
	// end sBenefits
